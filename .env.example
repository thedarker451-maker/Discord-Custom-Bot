# Discord Bot Configuration (Example)
# Copy this file to .env and fill in your actual values

# 🔐 Bot Token (REQUIRED - Get from Discord Developer Portal)
# https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here_replace_this

# ⚡ Bot Command Prefix
PREFIX=!

# 👤 Owner Discord ID (Your Discord User ID)
OWNER_ID=your_discord_user_id_here

# 📊 Database Configuration (Optional)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=discord_bot_db

# 🌍 External API Keys (Optional)
API_KEY=your_api_key_here
WEATHER_API_KEY=your_weather_api_key

# 🌐 Environment
NODE_ENV=development

# 🔗 Webhook URLs (Optional for logging)
LOG_WEBHOOK=your_log_webhook_url
ERROR_WEBHOOK=your_error_webhook_url
